{
    "$schema":  "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName":  "开源豆包语音输入法",
    "version":  "0.1.0",
    "identifier":  "com.doubao.ime",
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:5173",
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "",
                                    "width":  120,
                                    "height":  120,
                                    "resizable":  false,
                                    "decorations":  false,
                                    "transparent":  true,
                                    "alwaysOnTop":  true,
                                    "skipTaskbar":  true,
                                    "focus":  true,
                                    "visible":  true,
                                    "center":  true,
                                    "shadow":  false
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "resources":  [
                                     "../engine/voice_engine.py",
                                     "../engine/requirements.txt"
                                 ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               }
}
